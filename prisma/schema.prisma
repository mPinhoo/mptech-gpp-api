generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cliente {
  id             String          @id @default(uuid())
  nome           String
  email          String?
  telefone       String?
  documento      String?
  endereco       String?
  ativo          Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  pedidos        Pedido[]
  precificacoes  Precificacao[]
}

enum StatusProduto {
  ATIVO
  INATIVO
  FORA_DE_CICLO
}

model Produto {
  id          String        @id @default(uuid())
  nome        String
  categoria   String
  preco       Decimal       @db.Decimal(10, 2)
  status      StatusProduto @default(ATIVO)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  itensPedido ItemPedido[]
}

model MateriaPrima {
  id               String    @id @default(uuid())
  nome             String
  unidade          String    @default("un")
  precoCusto       Decimal   @db.Decimal(10, 2) @default(0)
  quantidade       Int       @default(0)
  quantidadeMinima Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  despesas         Despesa[]
}

model Despesa {
  id             String        @id @default(uuid())
  descricao      String
  valor          Decimal       @db.Decimal(10, 2)
  materiaPrimaId String?
  materiaPrima   MateriaPrima? @relation(fields: [materiaPrimaId], references: [id])
  createdAt      DateTime      @default(now())
}

enum StatusPedido {
  PENDENTE
  APROVADO
  CONCLUIDO
  CANCELADO
}

model Pedido {
  id              String        @id @default(uuid())
  numero          String        @unique
  clienteId       String
  cliente         Cliente       @relation(fields: [clienteId], references: [id])
  dataPedido      DateTime
  prazoEntrega    DateTime
  status          StatusPedido  @default(PENDENTE)
  valorTotal      Decimal       @db.Decimal(10, 2)
  enviadoCliente  Boolean       @default(false)
  kanbanColunaId  String?
  kanbanColuna    KanbanColuna? @relation(fields: [kanbanColunaId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  itens           ItemPedido[]
}

model KanbanColuna {
  id        String   @id @default(uuid())
  nome      String
  ordem     Int      @default(0)
  sistema   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pedidos   Pedido[]
}

model ItemPedido {
  id            String  @id @default(uuid())
  pedidoId      String
  pedido        Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produtoId     String
  produto       Produto @relation(fields: [produtoId], references: [id])
  quantidade    Int
  precoUnitario Decimal @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)
}

model Precificacao {
  id              String   @id @default(uuid())
  nome            String
  categoria       String?
  descricao       String?
  clienteId       String?
  cliente         Cliente? @relation(fields: [clienteId], references: [id])
  observacoes     String?
  tempoProducao   Decimal  @db.Decimal(10, 2) @default(0)
  valorHora       Decimal  @db.Decimal(10, 2) @default(0)
  taxaMarketplace Decimal  @db.Decimal(5, 2)  @default(0)
  taxaCartao      Decimal  @db.Decimal(5, 2)  @default(0)
  impostos        Decimal  @db.Decimal(5, 2)  @default(0)
  taxasAdicionais Decimal  @db.Decimal(5, 2)  @default(0)
  margemLucro     Decimal  @db.Decimal(5, 2)  @default(0)
  quantidade      Int      @default(1)
  custoMateriais  Decimal  @db.Decimal(10, 2) @default(0)
  custoMaoDeObra  Decimal  @db.Decimal(10, 2) @default(0)
  totalCustosFixos Decimal @db.Decimal(10, 2) @default(0)
  totalExtras     Decimal  @db.Decimal(10, 2) @default(0)
  totalTaxas      Decimal  @db.Decimal(10, 2) @default(0)
  subtotal        Decimal  @db.Decimal(10, 2) @default(0)
  lucroValor      Decimal  @db.Decimal(10, 2) @default(0)
  precoFinal      Decimal  @db.Decimal(10, 2) @default(0)
  precoUnitario   Decimal  @db.Decimal(10, 2) @default(0)
  status          String   @default("RASCUNHO")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  materiais       MaterialPrecificacao[]
  custosFixos     CustoFixoPrecificacao[]
  extras          ExtraPrecificacao[]
}

model MaterialPrecificacao {
  id              String        @id @default(uuid())
  precificacaoId  String
  precificacao    Precificacao  @relation(fields: [precificacaoId], references: [id], onDelete: Cascade)
  nome            String
  custoUnitario   Decimal       @db.Decimal(10, 2)
  quantidade      Decimal       @db.Decimal(10, 2)
  subtotal        Decimal       @db.Decimal(10, 2)
}

model CustoFixoPrecificacao {
  id              String        @id @default(uuid())
  precificacaoId  String
  precificacao    Precificacao  @relation(fields: [precificacaoId], references: [id], onDelete: Cascade)
  nome            String
  valor           Decimal       @db.Decimal(10, 2)
}

model ExtraPrecificacao {
  id              String        @id @default(uuid())
  precificacaoId  String
  precificacao    Precificacao  @relation(fields: [precificacaoId], references: [id], onDelete: Cascade)
  nome            String
  valor           Decimal       @db.Decimal(10, 2)
}
