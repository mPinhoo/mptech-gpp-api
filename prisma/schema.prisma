generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cliente {
  id             String          @id @default(uuid())
  nome           String
  email          String?
  telefone       String?
  documento      String?
  endereco       String?
  ativo          Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  pedidos        Pedido[]
}

enum StatusProduto {
  ATIVO
  INATIVO
  FORA_DE_CICLO
}

model Produto {
  id          String        @id @default(uuid())
  nome        String
  categoria   String
  descricao   String?
  qtdPorHora  Decimal       @db.Decimal(10, 2) @default(1)
  preco       Decimal       @db.Decimal(10, 2)
  status      StatusProduto @default(ATIVO)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  itensPedido ItemPedido[]
  materiais   MaterialProduto[]
}

model MateriaPrima {
  id               String            @id @default(uuid())
  nome             String
  unidade          String            @default("un")
  precoCusto       Decimal           @db.Decimal(10, 2) @default(0)
  quantidade       Int               @default(0)
  quantidadeMinima Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  despesas         Despesa[]
  materiaisProduto MaterialProduto[]
}

model MaterialProduto {
  id             String       @id @default(uuid())
  produtoId      String
  produto        Produto      @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  materiaPrimaId String
  materiaPrima   MateriaPrima @relation(fields: [materiaPrimaId], references: [id])
  quantidade     Decimal      @db.Decimal(10, 2)
  custoUnitario  Decimal      @db.Decimal(10, 2)
  subtotal       Decimal      @db.Decimal(10, 2)
}

model Despesa {
  id             String        @id @default(uuid())
  descricao      String
  valor          Decimal       @db.Decimal(10, 2)
  materiaPrimaId String?
  materiaPrima   MateriaPrima? @relation(fields: [materiaPrimaId], references: [id])
  createdAt      DateTime      @default(now())
}

enum StatusPedido {
  PENDENTE
  APROVADO
  CONCLUIDO
  CANCELADO
}

model Pedido {
  id              String        @id @default(uuid())
  numero          String        @unique
  clienteId       String
  cliente         Cliente       @relation(fields: [clienteId], references: [id])
  dataPedido      DateTime
  prazoEntrega    DateTime
  status          StatusPedido  @default(PENDENTE)
  valorTotal      Decimal       @db.Decimal(10, 2)
  enviadoCliente  Boolean       @default(false)
  kanbanColunaId  String?
  kanbanColuna    KanbanColuna? @relation(fields: [kanbanColunaId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  itens           ItemPedido[]
  extras          ExtraPedido[]
}

model ExtraPedido {
  id        String  @id @default(uuid())
  pedidoId  String
  pedido    Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  nome      String
  valor     Decimal @db.Decimal(10, 2)
}

model KanbanColuna {
  id        String   @id @default(uuid())
  nome      String
  ordem     Int      @default(0)
  sistema   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pedidos   Pedido[]
}

model ItemPedido {
  id            String  @id @default(uuid())
  pedidoId      String
  pedido        Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produtoId     String
  produto       Produto @relation(fields: [produtoId], references: [id])
  quantidade    Int
  precoUnitario Decimal @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)
}

model ConfigPrecificacao {
  id              String   @id @default(uuid())
  salarioMensal   Decimal  @db.Decimal(10, 2) @default(0)
  horasSemanais   Decimal  @db.Decimal(5, 2)  @default(40)
  semanasMes      Decimal  @db.Decimal(5, 2)  @default(4)
  diasTrabalhados Int      @default(22)
  horasDia        Decimal  @db.Decimal(5, 2)  @default(8)
  taxaMarketplace Decimal  @db.Decimal(5, 2)  @default(0)
  taxaCartao      Decimal  @db.Decimal(5, 2)  @default(0)
  impostos        Decimal  @db.Decimal(5, 2)  @default(0)
  taxasAdicionais Decimal  @db.Decimal(5, 2)  @default(0)
  margemLucro     Decimal  @db.Decimal(5, 2)  @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  custosFixos     CustoFixoConfig[]
}

model CustoFixoConfig {
  id               String            @id @default(uuid())
  configId         String
  config           ConfigPrecificacao @relation(fields: [configId], references: [id], onDelete: Cascade)
  nome             String
  valor            Decimal           @db.Decimal(10, 2)
}
